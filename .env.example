# ============================================================
# RAG System - Variabili d'Ambiente
# Copia questo file in .env e modifica i valori
# ============================================================

# LLM API Key (OpenAI-compatible) - UNICA source per la API key
# Per Ollama locale: lascia "ollama" (default se non impostata)
# Per LM Studio locale: "lm-studio"
# Per OpenAI: "sk-..."
# Per Together/Groq/ecc: la relativa API key
LLM_API_KEY=ollama

# MCP Server - Porta per SSE transport (default 8000)
# Usata da docker-compose per il servizio mcp
MCP_PORT=8000
